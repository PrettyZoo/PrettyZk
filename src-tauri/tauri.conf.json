{
  "$schema": "https://raw.githubusercontent.com/nicedoc/nicedoc/master/schemas/tauri-schema.json",
  "productName": "PrettyZk",
  "version": "2.1.1",
  "identifier": "cc.cc1234.prettyzk",
  "build": {
    "frontendDist": "../app/src/main/resources/web",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../webapp && npm run dev",
    "beforeBuildCommand": "cd ../webapp && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PrettyZk",
        "width": 1050,
        "height": 650,
        "minWidth": 900,
        "minHeight": 500,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
